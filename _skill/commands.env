# Single source of truth for the literal command strings shown in the
# llm-guidelines docs (website skill page and skill repo README). Edit a
# value here and re-run ./generate-skill.sh; both consumers update.
#
# Shell-source-friendly. Used by generate-skill.sh via `. _skill/commands.env`
# and exported into the perl substitution step that renders the templates in
# `_skill/`. No quoting is needed at the call site since perl reads the values
# from the environment.

CMD_MARKETPLACE_ADD='/plugin marketplace add se-uhd/llm-guidelines-skill'
CMD_PLUGIN_INSTALL='/plugin install llm-guidelines'
CMD_MARKETPLACE_UPDATE='/plugin marketplace update llm-guidelines'
CMD_RELOAD_PLUGINS='/reload-plugins'
CMD_CODEX_MARKETPLACE_ADD='codex plugin marketplace add se-uhd/llm-guidelines-skill'
CMD_CODEX_PLUGIN_INSTALL='codex plugin add llm-guidelines@se-uhd'
CMD_CODEX_MARKETPLACE_UPGRADE='codex plugin marketplace upgrade se-uhd'
CMD_INVOKE_EXPLORE='/llm-guidelines:explore'
CMD_INVOKE_REVIEW='/llm-guidelines:review'
CMD_INVOKE_REVIEW_TEX='/llm-guidelines:review path/to/paper.tex'
CMD_INVOKE_REVIEW_PDF='/llm-guidelines:review path/to/paper.pdf'
CMD_INVOKE_REVIEW_SUPP='/llm-guidelines:review path/to/paper.tex path/to/code-repo path/to/dataset'
